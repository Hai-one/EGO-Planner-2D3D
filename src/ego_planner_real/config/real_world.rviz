          Autocompute Value Bounds:
            Max Value: 1.7400000095367432
            Min Value: 0.03999999910593033
            Value: true
          Axis: Z
          Channel Name: z
          Class: rviz_default_plugins/PointCloud2
          Color: 255; 255; 255
          Color Transformer: AxisColor
          Decay Time: 0
          Enabled: true
          Invert Rainbow: false
